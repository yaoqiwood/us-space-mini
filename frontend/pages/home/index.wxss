.page { min-height: 100vh; padding: 48rpx 30rpx 164rpx; box-sizing: border-box; color: #3e3028; background: #fffaf4; }
.topbar, .header-actions, .card-heading, .plan-row, .love-note, .mood-pair, .bottom-nav { display: flex; align-items: center; }
.topbar { justify-content: space-between; margin: 6rpx 8rpx 24rpx; }
.brand { display: block; font-size: 38rpx; font-weight: 700; }
.heart, .note-heart { color: #f18d73; }
.tagline { display: block; margin-top: 8rpx; font-size: 25rpx; color: #978d85; }
.header-actions { gap: 16rpx; }
.round-action { display: flex; width: 70rpx; height: 70rpx; align-items: center; justify-content: center; border: 1rpx solid #f1dfcd; border-radius: 50%; color: #8c6041; font-size: 40rpx; background: #fffdf9; box-shadow: 0 5rpx 14rpx rgba(139, 99, 64, 0.08); }
.backend-status { display: inline-flex; gap: 10rpx; align-items: center; margin: 0 8rpx 16rpx; color: #948981; font-size: 21rpx; }
.status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #c8bfb7; }
.backend-status.online .status-dot { background: #68ad7e; }
.backend-status.error .status-dot { background: #e17c6d; }
.couple-hero { display: block; width: 100%; height: 282rpx; border: 1rpx solid #f2decb; border-radius: 26rpx; box-shadow: 0 9rpx 24rpx rgba(151, 105, 65, 0.11); }
.love-note { min-height: 76rpx; justify-content: space-between; margin-top: 24rpx; padding: 0 24rpx; border: 1rpx solid #f1e4d6; border-radius: 22rpx; color: #78655b; font-size: 24rpx; background: #fffefc; box-shadow: 0 6rpx 16rpx rgba(151, 105, 65, 0.08); }
.note-heart { font-size: 34rpx; }.note-arrow { color: #b8a99c; font-size: 44rpx; }
.quick-actions { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 8rpx; margin-top: 24rpx; padding: 22rpx 8rpx 18rpx; border: 1rpx solid #f2e4d6; border-radius: 26rpx; background: #fffdf9; }
.quick-action { display: flex; min-width: 0; flex-direction: column; align-items: center; gap: 12rpx; color: #4b4038; font-size: 20rpx; text-align: center; }
.quick-icon { display: flex; width: 76rpx; height: 76rpx; align-items: center; justify-content: center; border-radius: 22rpx; font-size: 50rpx; line-height: 1; }
.peach { color: #bd6545; background: #ffe4dc; }.gold { color: #d69223; background: #ffefcb; }.rose { color: #be625b; background: #ffe2e2; }.mint { color: #3a9d66; background: #dcf6e4; }.sky { color: #3688cf; background: #dceffc; }.lilac { color: #8564c7; background: #ede5ff; }
.dashboard { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-top: 24rpx; }
.card, .memory-card, .weather-card { box-sizing: border-box; border: 1rpx solid #f1e4d7; border-radius: 24rpx; background: #fffdf9; box-shadow: 0 7rpx 18rpx rgba(151, 105, 65, 0.07); }
.card { padding: 22rpx; }.plan-card, .mood-card { min-height: 280rpx; }
.card-heading { justify-content: space-between; font-size: 24rpx; font-weight: 700; }.all-link { color: #806f65; font-size: 20rpx; font-weight: 400; }
.plan-row { gap: 12rpx; margin-top: 22rpx; }.checkbox { width: 24rpx; height: 24rpx; border: 2rpx solid #eadccd; border-radius: 50%; }.plan-title { flex: 1; min-width: 0; overflow: hidden; font-size: 21rpx; white-space: nowrap; text-overflow: ellipsis; }.plan-time { color: #a79a91; font-size: 19rpx; }.add-plan { margin: 22rpx 0 0 30rpx; color: #97735d; font-size: 21rpx; }
.mood-pair { height: 196rpx; justify-content: space-around; text-align: center; }.mood-pair view { display: flex; flex-direction: column; gap: 10rpx; font-size: 21rpx; }.dog-face { color: #674b3a; font-size: 50rpx; font-weight: 700; }.dog-face.warm { color: #b7845f; }.mood-and { font-size: 32rpx; font-weight: 700; }
.memory-card, .weather-card { display: flex; min-height: 150rpx; align-items: center; justify-content: space-between; padding: 24rpx; }.memory-card { background: #fff6e8; }.memory-title, .memory-copy, .weather-city, .temperature, .weather-copy { display: block; }.memory-title { font-size: 25rpx; font-weight: 700; }.memory-copy { margin-top: 10rpx; color: #9d8c80; font-size: 20rpx; }.camera { color: #d89562; font-size: 66rpx; }
.weather-card { background: #eaf7ff; }.weather-city { font-size: 21rpx; font-weight: 700; }.temperature { margin-top: 8rpx; font-size: 56rpx; font-weight: 700; line-height: 1; }.temperature text { font-size: 24rpx; }.weather-copy { margin-top: 12rpx; font-size: 19rpx; }.sun { color: #f6b936; font-size: 82rpx; }
.bottom-nav { position: fixed; z-index: 10; right: 30rpx; bottom: 20rpx; left: 30rpx; height: 104rpx; justify-content: space-around; border: 1rpx solid #f1e4d7; border-radius: 54rpx; background: rgba(255, 253, 249, 0.97); box-shadow: 0 8rpx 24rpx rgba(151, 105, 65, 0.12); }
.nav-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; color: #968a81; font-size: 18rpx; }.nav-item > text:first-child { font-size: 34rpx; line-height: 1; }.nav-item.active { color: #ec8b70; }.nav-heart { display: flex; width: 86rpx; height: 86rpx; align-items: center; justify-content: center; border-radius: 50%; color: #fff; font-size: 50rpx; background: #f39a80; box-shadow: 0 7rpx 18rpx rgba(218, 116, 93, 0.32); }
