.page { min-height: 100vh; padding: 48rpx 30rpx 164rpx; box-sizing: border-box; color: #3e3028; background: #fffaf4; }
.topbar, .header-actions, .card-heading, .plan-row, .love-note, .mood-pair, .bottom-nav { display: flex; align-items: center; }
.topbar { justify-content: space-between; margin: 6rpx 8rpx 24rpx; }
.brand { display: flex; align-items: center; gap: 8rpx; font-size: 38rpx; font-weight: 700; }
.brand-heart { width: 32rpx; height: 32rpx; }
.tagline { display: block; margin-top: 8rpx; font-size: 25rpx; color: #978d85; }
.header-actions { gap: 16rpx; }
.round-action { display: flex; width: 70rpx; height: 70rpx; align-items: center; justify-content: center; }
.round-action-icon { width: 70rpx; height: 70rpx; }
.couple-hero { position: relative; width: 100%; height: 282rpx; overflow: hidden; border: 1rpx solid #f2decb; border-radius: 26rpx; box-sizing: border-box; background: #fbf4e6; box-shadow: 0 9rpx 24rpx rgba(151, 105, 65, 0.11); }
.anniversary-copy { position: relative; z-index: 2; width: 42%; padding: 42rpx 0 0 36rpx; box-sizing: border-box; }
.anniversary-label, .anniversary-days, .anniversary-unit { display: block; }
.anniversary-label { color: #7f5337; font-size: 29rpx; font-weight: 700; }
.anniversary-count { display: flex; align-items: baseline; margin-top: 2rpx; color: #1e1b19; }
.anniversary-days { font-size: 66rpx; font-weight: 700; line-height: 1.08; }.anniversary-unit { margin-left: 9rpx; font-size: 27rpx; }
.anniversary-date { display: inline-flex; max-width: 230rpx; align-items: center; gap: 6rpx; margin-top: 9rpx; padding: 5rpx 10rpx; border-radius: 18rpx; box-sizing: border-box; color: #796051; font-size: 15rpx; line-height: 1.2; white-space: nowrap; background: #f2dfc5; }
.date-heart { width: 20rpx; height: 20rpx; }.couple-hero-background { position: absolute; z-index: 1; top: 0; right: 0; bottom: 0; left: 0; width: 100%; height: 100%; }
.love-note { min-height: 76rpx; justify-content: space-between; margin-top: 24rpx; padding: 0 24rpx; border: 1rpx solid #f1e4d6; border-radius: 22rpx; color: #78655b; font-size: 24rpx; background: #fffefc; box-shadow: 0 6rpx 16rpx rgba(151, 105, 65, 0.08); }
.note-heart { width: 34rpx; height: 30rpx; }.note-arrow { width: 28rpx; height: 28rpx; }
.quick-actions { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 8rpx; margin-top: 24rpx; padding: 22rpx 8rpx 18rpx; border: 1rpx solid #f2e4d6; border-radius: 26rpx; background: #fffdf9; }
.quick-action { display: flex; min-width: 0; flex-direction: column; align-items: center; gap: 12rpx; color: #4b4038; font-size: 20rpx; text-align: center; }
.quick-icon { width: 76rpx; height: 76rpx; }
.dashboard { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-top: 24rpx; }
.card, .memory-card, .weather-card { box-sizing: border-box; border: 1rpx solid #f1e4d7; border-radius: 24rpx; background: #fffdf9; box-shadow: 0 7rpx 18rpx rgba(151, 105, 65, 0.07); }
.card { padding: 22rpx; }.plan-card, .mood-card { min-height: 280rpx; }
.card-heading { justify-content: space-between; font-size: 24rpx; font-weight: 700; }.plan-title-heading, .all-link { display: flex; align-items: center; }.plan-title-heading { gap: 4rpx; }.plan-heading-icon { width: 26rpx; height: 28rpx; }.all-link { gap: 2rpx; color: #806f65; font-size: 20rpx; font-weight: 400; }.all-link-arrow { width: 20rpx; height: 20rpx; }
.plan-row { gap: 12rpx; margin-top: 22rpx; }.checkbox-icon { width: 28rpx; height: 28rpx; flex: 0 0 auto; }.plan-title { flex: 1; min-width: 0; overflow: hidden; font-size: 21rpx; white-space: nowrap; text-overflow: ellipsis; }.plan-time { color: #a79a91; font-size: 19rpx; }.add-plan { margin: 22rpx 0 0 30rpx; color: #97735d; font-size: 21rpx; }
.mood-pair { height: 196rpx; justify-content: space-around; text-align: center; }.mood-option { display: flex; flex-direction: column; align-items: center; gap: 10rpx; font-size: 21rpx; }.mood-dog { width: 112rpx; height: 80rpx; }.mood-and { font-size: 32rpx; font-weight: 700; }
.memory-card, .weather-card { display: flex; min-height: 150rpx; align-items: center; justify-content: space-between; padding: 24rpx; }.memory-card { background: #fff6e8; }.memory-title, .memory-copy, .weather-city, .temperature, .weather-copy { display: block; }.memory-title { font-size: 25rpx; font-weight: 700; }.memory-copy { margin-top: 10rpx; color: #9d8c80; font-size: 20rpx; }.memory-camera { width: 144rpx; height: 90rpx; }
.weather-card { background: #eaf7ff; }.weather-city { font-size: 21rpx; font-weight: 700; }.temperature { margin-top: 8rpx; font-size: 56rpx; font-weight: 700; line-height: 1; }.temperature text { font-size: 24rpx; }.weather-copy { margin-top: 12rpx; font-size: 19rpx; }.sun { width: 96rpx; height: 96rpx; }
.bottom-nav { position: fixed; z-index: 10; right: 30rpx; bottom: 20rpx; left: 30rpx; height: 104rpx; justify-content: space-around; border: 1rpx solid #f1e4d7; border-radius: 54rpx; background: rgba(255, 253, 249, 0.97); box-shadow: 0 8rpx 24rpx rgba(151, 105, 65, 0.12); }
.nav-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; color: #968a81; font-size: 18rpx; }.nav-icon { width: 42rpx; height: 42rpx; }.nav-item.active { color: #ec8b70; }.nav-heart { display: flex; width: 86rpx; height: 86rpx; align-items: center; justify-content: center; }.nav-heart-icon { width: 64rpx; height: 58rpx; }
