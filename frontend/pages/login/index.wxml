<view class="page">
  <view class="header">
    <text class="title">Couple Space</text>
    <text class="subtitle">仅限已配置的两位成员使用</text>
  </view>
  <view wx:if="{{checkingWeChat}}" class="state">正在验证微信身份</view>
  <view wx:elif="{{bindingToken}}" class="form">
    <input placeholder="账号" value="{{username}}" bindinput="onUsernameInput" />
    <input password placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
    <button type="primary" loading="{{submitting}}" bindtap="onLogin">登录并绑定微信</button>
  </view>
  <view wx:else class="state">
    <text>{{errorMessage || "无法验证微信身份"}}</text>
    <button bindtap="verifyBackendAndLogin">重试</button>
  </view>
  <text wx:if="{{errorMessage && bindingToken}}" class="error">{{errorMessage}}</text>
</view>
