<view class="page">
  <view class="header">
    <text class="title">Couple Space</text>
    <text class="subtitle">仅限已配置的两位成员使用</text>
  </view>
  <view class="form">
    <input placeholder="账号" value="{{username}}" bindinput="onUsernameInput" />
    <input password placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
    <button type="primary" loading="{{submitting}}" bindtap="onLogin">登录并绑定微信</button>
  </view>
</view>
